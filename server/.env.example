# Server Environment Variables Template
# Copy this to .env and fill in real values

MASTER_KEY=generate-a-random-64-char-hex-string
JWT_SECRET=change-this-to-a-random-string
JWT_REFRESH_SECRET=change-this-to-another-random-string
PORT=3000
NODE_ENV=development

# Optional (production / deploy)
# CORS_ORIGINS: comma-separated frontend URLs allowed to call the API.
# CORS_ORIGINS=https://your-authenticator.example.com,https://your-demo.example.com
# DB_PATH: SQLite file location; point at a persistent disk in production.
# DB_PATH=/var/data/authenticator.db
